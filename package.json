{
  "name": "@sibyllai/lethe",
  "version": "1.0.0",
  "description": "Pre-AI repo sanitization — redact secrets before your code meets the LLM",
  "license": "MIT",
  "author": "{sibyllai}",
  "type": "module",
  "bin": {
    "lethe": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "src/catalog/"
  ],
  "keywords": [
    "security",
    "secrets",
    "redaction",
    "ai",
    "llm",
    "sanitization",
    "claude",
    "khoregos"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.1",
    "js-yaml": "^4.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^9.5.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
